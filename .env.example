# Variáveis do docker-compose.yml (raiz do projeto).
# O Docker Compose lê automaticamente o arquivo `.env` desta pasta e usa estes valores
# para interpolar `${...}` no compose. Copie para `.env` e defina uma senha própria:
#
#   cp .env.example .env
#
# O `.env` está no .gitignore — nunca commite credenciais reais.
# Gere a senha com: python -c "import secrets; print(secrets.token_hex(24))"
#
# Separação por ambiente: este arquivo vale APENAS para o desenvolvimento local.
# Em staging/produção o Postgres é gerenciado fora do compose e as credenciais entram
# como secrets do provedor/CI — ver docs/deploy-producao.md.

POSTGRES_USER=facilichat
POSTGRES_PASSWORD=troque-por-uma-senha-aleatoria
POSTGRES_DB=facilichat_db

# Papel RESTRITO usado pela API (item F08-01) — separado do papel administrativo acima.
# `gerenciar_banco.py reset`/`aplicar-rls` criam/atualizam este papel no Postgres e concedem
# apenas os privilégios necessários (SELECT/INSERT/UPDATE/DELETE nas tabelas, USAGE no schema e
# nas sequências) — nunca SUPERUSER, BYPASSRLS ou posse das tabelas. A API só conecta com ele.
APP_DB_USER=facilichat_app
APP_DB_PASSWORD=troque-por-outra-senha-aleatoria
