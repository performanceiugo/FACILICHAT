DATABASE_URL=postgresql+asyncpg://usuario:senha@localhost:5432/facilichat_db
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=gere-uma-chave-aleatoria-com-minimo-32-bytes
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
ANTHROPIC_API_KEY=sk-ant-...
# Origens de frontend autorizadas a chamar a API (CORS), separadas por vírgula.
# Em produção, troque pelos domínios reais (ex: https://app.seudominio.com).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Fechado por padrao: impede que POST /usuarios/ escolha qualquer EmpresaID publico.
# Para dev/onboarding assistido, habilite e informe exatamente uma Empresa ativa.
CADASTRO_PUBLICO_HABILITADO=false
CADASTRO_PUBLICO_EMPRESA_ID=
