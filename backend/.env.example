DATABASE_URL=postgresql+asyncpg://usuario:senha@localhost:5432/facilichat_db
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=gere-uma-chave-aleatoria-com-minimo-32-bytes
JWT_ALGORITHM=HS256
# Access token curto (item S15) — a sessão longa vem do refresh token, não deste valor.
JWT_EXPIRE_MINUTES=15
# Claims iss/aud do token (S14/B6). Defaults do código já servem; só troque se rodar múltiplos
# ambientes com o mesmo JWT_SECRET e precisar diferenciar quem emitiu/para quem vale o token.
# JWT_ISSUER=facilichat-api
# JWT_AUDIENCE=facilichat-clientes
# Validade do refresh token em dias (item S15). Default do código já é 30; só declare aqui se
# quiser um valor diferente.
# REFRESH_TOKEN_EXPIRE_DIAS=30
ANTHROPIC_API_KEY=sk-ant-...
DEBUG=false
# dev | staging | producao (item S10). Default do código já é "dev" — só declare aqui se este
# ambiente for staging, ou em produção, onde é OBRIGATÓRIO (ver .env.prod.example): com
# AMBIENTE=producao, `gerenciar_banco.py semear` recusa criar usuários demo com senha padrão.
# AMBIENTE=dev
# Swagger (/docs), ReDoc (/redoc) e /openapi.json (item S8). Default do código já é true (dev
# depende disso). Em produção: DESLIGUE (documenta a API publicamente, mapa pronto pra atacante).
# API_DOCS_HABILITADO=false
# Origens de frontend autorizadas a chamar a API (CORS), separadas por vírgula.
# Em produção, troque pelos domínios reais (ex: https://app.seudominio.com).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Fechado por padrao: impede que POST /usuarios/ escolha qualquer EmpresaID publico.
# Para dev/onboarding assistido, habilite e informe exatamente uma Empresa ativa.
CADASTRO_PUBLICO_HABILITADO=false
CADASTRO_PUBLICO_EMPRESA_ID=
# --- Cookie de sessão do painel web (S6) ---
# Os defaults do código são os de PRODUÇÃO (COOKIE_SECURE=true, SameSite=lax, sem domínio).
# Em dev o painel roda em http://localhost, então o cookie Secure não é enviado por http.
# Em produção: REMOVA a linha abaixo (ou use true) e sirva tudo por HTTPS.
COOKIE_SECURE=false
# lax | strict | none. "none" exige COOKIE_SECURE=true e só faz sentido em cookie de terceira
# parte — cenário que o proxy /api/* do Next evita. Ver docs/deploy-producao.md.
# COOKIE_SAMESITE=lax
# Vazio = cookie host-only. Preencher só para valer em subdomínios (ex: .facilichat.com).
# COOKIE_DOMAIN=
