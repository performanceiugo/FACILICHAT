# Caddyfile de produção do FaciliChat (item S9) — proxy TLS na frente do compose.
# Os placeholders {$VAR} vêm do `environment:` do serviço caddy no docker-compose.prod.yml
# (que por sua vez lê o .env da raiz). O Caddy obtém e RENOVA sozinho os certificados
# Let's Encrypt dos dois domínios — basta o DNS de cada um apontar para o IP do VPS
# e as portas 80/443 estarem abertas. HTTP→HTTPS é redirecionado automaticamente.

{
	# E-mail que o Let's Encrypt usa para avisos de expiração/problemas com o certificado
	email {$ACME_EMAIL}
}

# ---- Painel web (Next.js) -------------------------------------------------------------
# O navegador dos usuários só fala com este domínio; a API é alcançada pelo proxy
# /api/* do próprio Next (decisão do S6 — cookie de sessão first-party).
{$DOMINIO_PAINEL} {
	encode gzip zstd

	# HSTS (decisão do S16): o próprio Next não envia este header (em dev gravaria a
	# exigência de HTTPS para localhost) — ele pertence ao proxy TLS. Começa SEM
	# includeSubDomains/preload; adicionar só quando TODOS os subdomínios tiverem TLS.
	header Strict-Transport-Security "max-age=31536000"

	reverse_proxy web:3000
}

# ---- API (FastAPI) ---------------------------------------------------------------------
# Este domínio existe para o app MOBILE (Authorization: Bearer) e integrações futuras.
# O Caddy injeta X-Forwarded-For/-Proto automaticamente; o uvicorn os lê graças ao
# `--proxy-headers` do compose (rate limit por IP real, não pelo IP do proxy).
{$DOMINIO_API} {
	encode gzip zstd
	header Strict-Transport-Security "max-age=31536000"
	reverse_proxy backend:8000
}
