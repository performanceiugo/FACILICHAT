# Modelo do `.env` de PRODUÇÃO (item S9) — usado pelo docker-compose.prod.yml.
# No servidor:  cp .env.prod.example .env  &&  nano .env  &&  chmod 600 .env
#
# Regras (docs/deploy-producao.md):
#   - Segredo NUNCA entra no Git: este arquivo é só o modelo; o `.env` real vive apenas
#     no servidor (está no .gitignore).
#   - Uma chave/senha POR AMBIENTE — produção nunca reusa a senha de dev/staging.
#   - O compose falha cedo (com mensagem clara) se alguma variável obrigatória faltar.

# ---- Domínios (DNS de ambos apontando para o IP do VPS) --------------------------------
# Sem "https://" — só o hostname. O Caddy emite o certificado TLS de cada um sozinho.
DOMINIO_PAINEL=painel.seudominio.com.br
DOMINIO_API=api.seudominio.com.br

# E-mail para os avisos do Let's Encrypt (expiração/problemas de certificado)
ACME_EMAIL=voce@seudominio.com.br

# ---- Postgres (container `db` do compose, volume persistente pgdata_prod) --------------
# Gere a senha com: python -c "import secrets; print(secrets.token_hex(24))"
POSTGRES_USER=facilichat
POSTGRES_PASSWORD=troque-por-uma-senha-aleatoria-de-producao
POSTGRES_DB=facilichat_db

# ---- Backend (FastAPI) ------------------------------------------------------------------
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Mínimo de 32 bytes — a API recusa chave curta ou placeholder na subida.
# ⚠️ Rotacionar esta chave derruba o login de TODOS os usuários.
JWT_SECRET=troque-por-uma-chave-aleatoria-de-producao

# Marca este ambiente como produção (item S10) — `gerenciar_banco.py semear` recusa rodar quando
# AMBIENTE=producao, para nunca criar usuários de demonstração com senha padrão aqui.
AMBIENTE=producao

# Chave da API da Anthropic (IA). Enquanto o produto não usa IA, um placeholder é aceito.
ANTHROPIC_API_KEY=placeholder-ia-ainda-nao-usada

# ---- Backup (deploy/backup-banco.sh) ----------------------------------------------------
# Destino EXTERNO das cópias diárias do banco, no formato remote:caminho do rclone
# (ex.: um bucket S3/Backblaze ou um Google Drive configurado com `rclone config`).
# Vazio = o script só gera o dump local em ./backups e avisa que não há cópia externa.
BACKUP_RCLONE_DESTINO=
# Quantos dias de dumps locais manter antes de apagar (as cópias externas não são tocadas)
BACKUP_RETENCAO_DIAS=7
